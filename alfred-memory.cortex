$8: LESSONS

LNG:survival_core_direction{type:"architectural_insight", cause:"12 premisas del arquitecto", lesson:"CODEC-CORTEX must evolve from dense format to contextual survival system. When everything else is lost, FCS/OBJ/CNST/STP still survive", prevention:"survive attribute in all critical sigils"}
LNG:section7_means_use{type:"process", cause:"Confusion between design and execution", lesson:"Design operativo (§7) must show functional use of the deliverable in the project, NOT RE execution steps. Execution goes in §10", prevention:"RE template with clear section boundaries"}
LNG:load_vs_degrade{type:"architecture", cause:"Discussion about load/degrade order", lesson:"Context loading: P0->P5 (priority first). Degradation: P5->P1 (least critical first). P0 never touched during degradation", prevention:"!survive_degrade and !survive_priority rules"}
LNG:no_release_without_parser{type:"process", cause:"Impulse to tag before implementation exists", lesson:"Do not tag v0.3.0-spec before parser or automated benchmark exists. CHANGELOG uses [Unreleased]", prevention:"Pre-release checklist in workbook"}

