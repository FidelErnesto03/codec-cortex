$0: MINIMAL LOCAL GLOSSARY

# -- $0: MINIMAL LOCAL GLOSSARY --
# Sigil | Name       | Type      | Risk | Cognitive Layer | Description
# IDN   | identity   | attrs     | B    | Semantic       | Actor identity
# DOM   | domain     | attrs     | B    | Semantic       | Scope and context
# TAG   | tag        | attrs     | B    | Semantic       | Classification metadata
# FCS   | focus      | attrs     | H    | Working        | Attention anchor
# OBJ   | objective  | attrs     | H    | Working        | Active goal
# WRK   | work       | attrs     | M    | Working        | Operational state
# CNST  | constraint | attrs     | H    | Prefrontal     | Hard boundary
# KNW   | knowledge  | attrs     | B    | Semantic       | Stable knowledge
# SES   | session    | attrs     | M    | Episodic       | Compressed episode
# LNG   | lesson     | attrs     | M    | Episodic       | Learned heuristic
# REF   | reference  | attrs     | B    | Semantic       | External reference
# STP   | step       | attrs     | M    | Working        | Next immediate action
# AUD   | audit      | attrs     | M    | Prefrontal     | Audit record
# RSK   | risk       | attrs     | M    | Prefrontal     | Risk with mitigation
# CLAIM | claim      | attrs     | M    | Prefrontal     | Verifiable claim
# LIM   | limit      | attrs     | M    | Prefrontal     | Operational limit
# !     | rule       | attrs     | H    | Prefrontal     | Mandatory rule
#
# Types:
# attrs = key:value pairs
# cuerpo = free text body
# bloque = verbatim multiline block

$1: IDENTITY

IDN:human{name:"Fidel Ernesto Lozada A.", role:"Creator & Architect", academic:"Systems Engineer / MSc. Management Sciences", github:"FidelErnesto03", email:"fidelernesto@gmail.com", git_user:"Fidel Lozada", git_email:"fidel.lozada@vatrox.com", gh_auth:"SSH"}
IDN:agent{name:"alfred", role:"Protocol implementation and documentation agent", type:"AI coding agent", home:"~/.hermes/skills/", runtime:"Hermes Agent"}
DOM:project{area:"CODEC-CORTEX — Cognitive Operational Retrieval & Execution Template", license:"MIT", repo:"github.com/FidelErnesto03/codec-cortex", version:"v0.3.0", dialect_cycle:"CORTEX-CONSOLIDATION-001"}
TAG:memory{source:"hermes_persistent_store", format:"c1", encoding_date:"2026-06-24"}

$2: CONSTRAINTS

CNST:output{rule:"format: HCORTEX. tables_over_prose, puml_over_ascii, prose_as_last_resort", severity:"blocking", survive:"min"}
CNST:language{rule:"structural: EN, semantic: ES, output: ES", severity:"blocking", survive:"min"}
CNST:re_completeness{rule:"RE must be 100% complete (quality_contract, ACs, tasks, risks, procedure) before transitioning to open", severity:"blocking", survive:"min"}
CNST:learning{rule:"knowledge matures by USER decision, not counters. promote requires human confirmation. detect_recurrence(threshold=3) -> ask_user -> promote/decay", severity:"blocking", survive:"min"}
CNST:cortex_rules{rule:"skills self-contained (no MCP, no external tools), structural EN + semantic ES, delete=degrade level (never wipe), GATE exit mandatory", severity:"blocking", survive:"min"}
CNST:publication{rule:"publication with authorship: AUTHORS, CITATION.cff, CODEOWNERS, SPDX, semver", severity:"warning", survive:"recovery"}

