GEN:versiculo{id:"21.1",capitulo:21,verso:1,texto:"Jehová visitó a Sara, como había dicho, e hizo Jehová con Sara como había hablado."}
GEN:versiculo{id:"21.2",capitulo:21,verso:2,texto:"Y concibió Sara, y dio a luz un hijo a Abraham en su vejez, en el tiempo que Dios le había dicho."}
