# ============================================
# CAPÍTULO 15: EL PACTO CON ABRAHAM
# ============================================

$15: EL PACTO CON ABRAHAM:DATA

GEN:resumen{capitulo:15,titulo:"La confirmación del pacto",esencia:"Dios confirma el pacto con Abraham, profetiza el cautiverio en Egipto."}

GEN:evento{nombre:"Visión",capitulo:15,dia:null,accion:"Dios habla a Abraham en visión",resultado:"Promesa de descendencia"}
GEN:evento{nombre:"Pacto formal",capitulo:15,dia:null,accion:"Dios hace pasar animales cortados",resultado:"Confirmación del pacto"}

GEN:pacto{nombre:"Abraham",partes:"Dios y Abraham",condicion:"Fe",promesa:"Tierra desde Nilo hasta Éufrates",capitulo:15}

GEN:versiculo{id:"15.1",capitulo:15,verso:1,texto:"Después de estas cosas vino palabra de Jehová a Abram en visión, diciendo: No temas, Abram; yo soy tu escudo, y tu galardón será sobremanera grande."}
GEN:versiculo{id:"15.5",capitulo:15,verso:5,texto:"Y lo llevó fuera, y le dijo: Mira ahora los cielos, y cuenta las estrellas, si las puedes contar. Y le dijo: Así será tu descendencia."}
GEN:versiculo{id:"15.6",capitulo:15,verso:6,texto:"Y creyó a Jehová, y le fue contado por justicia."}
GEN:versiculo{id:"15.13",capitulo:15,verso:13,texto:"Entonces Jehová dijo a Abram: Ten por cierto que tu descendencia será extranjera en tierra que no es suya, y los servirán, y los oprimirán cuatrocientos años."}

# ============================================
# CAPÍTULO 16: ISMAEL
# ============================================

$16: ISMAEL:DATA

GEN:resumen{capitulo:16,titulo:"El nacimiento de Ismael",esencia:"Sara da a Agar a Abraham, Agar concibe, es despreciada, huye, y es enviada de vuelta."}

GEN:evento{nombre:"Agar huye",capitulo:16,dia:null,accion:"Agar huye de Sara",resultado:"El ángel la encuentra"}
GEN:evento{nombre:"Promesa sobre Ismael",capitulo:16,dia:null,accion:"El ángel promete numerosa descendencia",resultado:"Ismael nace"}

GEN:personaje{nombre:"Agar",edad:null,vida:null,descendencia:"Ismael",muerte:null}
GEN:personaje{nombre:"Ismael",edad:null,vida:137,descendencia:"12 príncipes",muerte:137}

GEN:versiculo{id:"16.10",capitulo:16,verso:10,texto:"También le dijo el ángel de Jehová: Multiplicaré tanto tu descendencia, que no será contada por la multitud."}
GEN:versiculo{id:"16.11",capitulo:16,verso:11,texto:"Y además le dijo: He aquí que has concebido, y darás a luz un hijo, y llamarás su nombre Ismael, porque Jehová ha oído tu aflicción."}

GEN:relacion{origen:"Abraham"|destino:"Agar"|tipo:"esposo"|capitulo:16}
GEN:relacion{origen:"Agar"|destino:"Ismael"|tipo:"madre"|capitulo:16}

