# CAPÍTULO 43: LA SEGUNDA VISITA
# ============================================

$43: LA SEGUNDA VISITA:FLOW

GEN:resumen{capitulo:43,titulo:"Benjamín en Egipto",esencia:"Los hermanos vuelven con Benjamín, José los recibe y prepara un banquete."}

GEN:evento{nombre:"Benjamín",capitulo:43,dia:null,accion:"Los hermanos traen a Benjamín",resultado:"José llora al verlo"}
GEN:evento{nombre:"Banquete",capitulo:43,dia:null,accion:"José da un banquete",resultado:"Los hermanos comen y beben"}

GEN:versiculo{id:"43.1",capitulo:43,verso:1,texto:"El hambre era grave en la tierra."}
GEN:versiculo{id:"43.30",capitulo:43,verso:30,texto:"Entonces José se apresuró, porque se conmovieron sus entrañas a causa de su hermano, y buscó donde llorar; y entró en su cámara, y lloró allí."}

# ============================================
# CAPÍTULO 44: LA PRUEBA DE LA COPA
# ============================================

$44: LA PRUEBA DE LA COPA:FLOW

GEN:resumen{capitulo:44,titulo:"La copa de José",esencia:"José hace poner su copa en el saco de Benjamín y los acusa."}

GEN:evento{nombre:"Prueba final",capitulo:44,dia:null,accion:"La copa es hallada en el saco de Benjamín",resultado:"Judá se ofrece como sustituto"}

GEN:versiculo{id:"44.18",capitulo:44,verso:18,texto:"Entonces Judá se acercó a él, y dijo: Señor mío, permite tu siervo que hable una palabra a mi señor..."}
GEN:versiculo{id:"44.33",capitulo:44,verso:33,texto:"Por tanto, te ruego que quede tu siervo en lugar del joven, por siervo de mi señor, y que el joven suba con sus hermanos."}

GEN:relacion{origen:"Judá"|destino:"Benjamín"|tipo:"intercede"|capitulo:44}

# ============================================
# CAPÍTULO 45: JOSÉ SE DA A CONOCER
# ============================================

$45: JOSÉ SE DA A CONOCER:FLOW

GEN:resumen{capitulo:45,titulo:"La revelación",esencia:"José se revela a sus hermanos, los perdona, y los envía por Jacob."}

GEN:evento{nombre:"Revelación",capitulo:45,dia:null,accion:"José se da a conocer",resultado:"Sus hermanos se aterran"}
GEN:evento{nombre:"Perdón",capitulo:45,dia:null,accion:"José los perdona",resultado:"Los envía por Jacob"}

GEN:versiculo{id:"45.1",capitulo:45,verso:1,texto:"Entonces José no pudo contenerse delante de todos los que estaban a su lado, y clamó: Haced salir a todos de mi presencia..."}
GEN:versiculo{id:"45.3",capitulo:45,verso:3,texto:"Y dijo José a sus hermanos: Yo soy José; ¿vive aún mi padre?"}
GEN:versiculo{id:"45.5",capitulo:45,verso:5,texto:"Ahora, pues, no os entristezcáis, ni os pese de haberme vendido acá; porque para preservación de vida me envió Dios delante de vosotros."}

GEN:relacion{origen:"José"|destino:"Hermanos"|tipo:"perdona"|capitulo:45}

# ============================================
# CAPÍTULO 46: JACOB BAJA A EGIPTO
# ============================================

$46: JACOB BAJA A EGIPTO:FLOW

GEN:resumen{capitulo:46,titulo:"El descenso a Egipto",esencia:"Jacob y toda su familia bajan a Egipto, Dios le da una visión."}

GEN:evento{nombre:"Visión",capitulo:46,dia:null,accion:"Dios habla a Jacob en Beerseba",resultado:"No temas bajar a Egipto"}
GEN:evento{nombre:"Llegada",capitulo:46,dia:null,accion:"Jacob llega a Egipto con 70 personas",resultado:"José lo recibe"}

GEN:personaje{nombre:"Jacob",edad:130,vida:147,descendencia:"12 hijos",muerte:147}

GEN:versiculo{id:"46.2",capitulo:46,verso:2,texto:"Y habló Dios a Israel en visiones de noche, y dijo: Jacob, Jacob. Y él respondió: Heme aquí."}
GEN:versiculo{id:"46.3",capitulo:46,verso:3,texto:"Y dijo: Yo soy Dios, el Dios de tu padre; no temas de descender a Egipto, porque allí te haré una gran nación."}
GEN:versiculo{id:"46.29",capitulo:46,verso:29,texto:"José preparó su carro, y fue a recibir a Israel su padre en Gosén..."}

GEN:relacion{origen:"Jacob"|destino:"Egipto"|tipo:"desciende"|capitulo:46}

# ============================================
# CAPÍTULO 47: JACOB EN EGIPTO
# ============================================

$47: JACOB EN EGIPTO:FLOW

GEN:resumen{capitulo:47,titulo:"La administración de José",esencia:"Jacob y su familia se establecen en Gosén, José administra el grano."}

GEN:evento{nombre:"Gosén",capitulo:47,dia:null,accion:"Jacob se establece en Gosén",resultado:"La familia prospera"}
GEN:evento{nombre:"Administración",capitulo:47,dia:null,accion:"José compra tierras para Faraón",resultado:"Egipto sobrevive la hambruna"}

GEN:lugar{nombre:"Gosén",tipo:"tierra",significado:"Región de Egipto",capitulo:47}

GEN:versiculo{id:"47.6",capitulo:47,verso:6,texto:"La tierra de Egipto está delante de ti; haz habitar a tu padre y a tus hermanos en lo mejor de la tierra..."}
GEN:versiculo{id:"47.9",capitulo:47,verso:9,texto:"Y Jacob respondió a Faraón: Los días de los años de mi peregrinación son ciento treinta años..."}
GEN:versiculo{id:"47.12",capitulo:47,verso:12,texto:"Y José sustentó a su padre y a sus hermanos, y a toda la casa de su padre, con pan..."}

# ============================================
# CAPÍTULO 48: JACOB BENDICE A EFRAÍN Y MANASÉS
# ============================================

$48: JACOB BENDICE A EFRAÍN Y MANASÉS:FLOW

GEN:resumen{capitulo:48,titulo:"La bendición de los hijos de José",esencia:"Jacob bendice a Efraín y Manasés, poniendo al menor sobre el mayor."}

GEN:evento{nombre:"Bendición",capitulo:48,dia:null,accion:"Jacob bendice a Efraín y Manasés",resultado:"Efraín es puesto sobre Manasés"}

GEN:personaje{nombre:"Efraín",edad:null,vida:null,descendencia:null,muerte:null}
GEN:personaje{nombre:"Manasés",edad:null,vida:null,descendencia:null,muerte:null}

GEN:profecia{nombre:"Bendición de Efraín",capitulo:48,destinatario:"Efraín",texto:"El ángel que me libra de todo mal, bendiga a estos jóvenes..."}

GEN:versiculo{id:"48.1",capitulo:48,verso:1,texto:"Después de estas cosas, dijeron a José: He aquí, tu padre está enfermo. Y él tomó consigo a sus dos hijos, Manasés y Efraín."}
GEN:versiculo{id:"48.14",capitulo:48,verso:14,texto:"Entonces Israel extendió su mano derecha, y la puso sobre la cabeza de Efraín, que era el menor, y su mano izquierda sobre la cabeza de Manasés..."}
GEN:versiculo{id:"48.19",capitulo:48,verso:19,texto:"Y su padre no quiso, y dijo: Lo sé, hijo mío, lo sé; también él vendrá a ser un pueblo, y será también engrandecido; pero su hermano menor será más grande que él..."}

GEN:relacion{origen:"Jacob"|destino:"Efraín"|tipo:"bendice"|capitulo:48}
GEN:relacion{origen:"Jacob"|destino:"Manasés"|tipo:"bendice"|capitulo:48}

# ============================================
# CAPÍTULO 49: LAS BENDICIONES DE JACOB
# ============================================

$49: LAS BENDICIONES DE JACOB:FLOW

GEN:resumen{capitulo:49,titulo:"Las profecías de Jacob",esencia:"Jacob bendice y profetiza sobre cada uno de sus 12 hijos."}

GEN:profecia{nombre:"Rubén",capitulo:49,destinatario:"Rubén",texto:"Rubén, tú eres mi primogénito, mi fortaleza, y el principio de mi vigor; excelso en dignidad, excelso en poder. Impetuoso como las aguas, no tú sobresalirás..."}
GEN:profecia{nombre:"Simeón y Leví",capitulo:49,destinatario:"Simeón y Leví",texto:"Simeón y Leví son hermanos; armas de iniquidad son sus armas. En su secreto no entre mi alma..."}
GEN:profecia{nombre:"Judá",capitulo:49,destinatario:"Judá",texto:"Judá, te alabarán tus hermanos; tu mano en la cerviz de tus enemigos; se inclinarán a ti los hijos de tu padre. No será quitado el cetro de Judá..."}
GEN:profecia{nombre:"Zabulón",capitulo:49,destinatario:"Zabulón",texto:"Zabulón habitará a la orilla del mar..."}
GEN:profecia{nombre:"Isacar",capitulo:49,destinatario:"Isacar",texto:"Isacar, asno fuerte, que se recuesta entre dos cercas..."}
GEN:profecia{nombre:"Dan",capitulo:49,destinatario:"Dan",texto:"Dan juzgará a su pueblo, como una de las tribus de Israel..."}
GEN:profecia{nombre:"Gad",capitulo:49,destinatario:"Gad",texto:"Gad, escuadrón lo acometerá, mas él acometerá al fin..."}
GEN:profecia{nombre:"Aser",capitulo:49,destinatario:"Aser",texto:"El pan de Aser será substancial, y él dará delicias de rey..."}
GEN:profecia{nombre:"Neftalí",capitulo:49,destinatario:"Neftalí",texto:"Neftalí, cierva suelta, que echa dichosos renuevos..."}
GEN:profecia{nombre:"José",capitulo:49,destinatario:"José",texto:"Rama fructífera es José, rama fructífera junto a la fuente, sus vástagos se extienden sobre el muro..."}
GEN:profecia{nombre:"Benjamín",capitulo:49,destinatario:"Benjamín",texto:"Benjamín, lobo rapaz; por la mañana devorará la presa, y por la tarde repartirá el botín."}

GEN:versiculo{id:"49.1",capitulo:49,verso:1,texto:"Y Jacob llamó a sus hijos, y dijo: Juntaos, y os declararé lo que os ha de acontecer en los días venideros."}
GEN:versiculo{id:"49.10",capitulo:49,verso:10,texto:"No será quitado el cetro de Judá, ni el legislador de entre sus pies, hasta que venga Siloh; y a él se congregarán los pueblos."}
GEN:versiculo{id:"49.33",capitulo:49,verso:33,texto:"Y cuando Jacob acabó de dar mandatos a sus hijos, recogió sus pies en la cama, y expiró, y fue reunido a su pueblo."}

# ============================================
# CAPÍTULO 50: LA MUERTE DE JACOB Y JOSÉ
# ============================================

$50: LA MUERTE DE JACOB Y JOSÉ:FLOW

GEN:resumen{capitulo:50,titulo:"El entierro y la promesa",esencia:"Jacob muere y es llevado a Canaán, José muere a los 110 años."}

GEN:evento{nombre:"Muerte de Jacob",capitulo:50,dia:null,accion:"Jacob muere a los 147 años",resultado:"José lo embalsama"}
GEN:evento{nombre:"Entierro",capitulo:50,dia:null,accion:"José lleva a Jacob a Canaán",resultado:"Lo entierra en la cueva de Macpela"}
GEN:evento{nombre:"Muerte de José",capitulo:50,dia:null,accion:"José muere a los 110 años",resultado:"Su cuerpo es embalsamado en Egipto"}

GEN:personaje{nombre:"Jacob",edad:null,vida:147,descendencia:"12 hijos",muerte:147}
GEN:personaje{nombre:"José",edad:null,vida:110,descendencia:"Efraín, Manasés",muerte:110}

GEN:versiculo{id:"50.1",capitulo:50,verso:1,texto:"Entonces José se echó sobre el rostro de su padre, y lloró sobre él, y lo besó."}
GEN:versiculo{id:"50.20",capitulo:50,verso:20,texto:"Vosotros pensasteis mal contra mí, pero Dios lo encaminó a bien, para hacer lo que vemos hoy, para mantener en vida a mucho pueblo."}
GEN:versiculo{id:"50.25",capitulo:50,verso:25,texto:"Y José hizo jurar a los hijos de Israel, diciendo: Dios ciertamente os visitará, y haréis subir mis huesos de aquí."}
GEN:versiculo{id:"50.26",capitulo:50,verso:26,texto:"Murió José a la edad de ciento diez años; y lo embalsamaron, y fue puesto en un ataúd en Egipto."}

GEN:relacion{origen:"José"|destino:"Jacob"|tipo:"entierra"|capitulo:50}
GEN:relacion{origen:"José"|destino:"Hermanos"|tipo:"consuela"|capitulo:50}

# ============================================
# FIN DEL GÉNESIS EN CORTEX
# ============================================