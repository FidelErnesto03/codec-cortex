GEN:lugar{nombre:"Moriah",tipo:"monte",significado:"Provisión",capitulo:22}

GEN:versiculo{id:"22.1",capitulo:22,verso:1,texto:"Después de estas cosas, Dios probó a Abraham, y le dijo: Abraham. Y él respondió: Heme aquí."}
GEN:versiculo{id:"22.2",capitulo:22,verso:2,texto:"Y dijo: Toma ahora tu hijo, tu único, Isaac, a quien amas, y vete a tierra de Moriah, y ofrécelo allí en holocausto sobre uno de los montes que yo te diré."}
GEN:versiculo{id:"22.8",capitulo:22,verso:8,texto:"Respondió Abraham: Dios se proveerá de cordero para el holocausto, hijo mío."}
GEN:versiculo{id:"22.12",capitulo:22,verso:12,texto:"No extiendas tu mano sobre el muchacho, ni le hagas nada; porque ya conozco que temes a Dios, y que no me rehusaste tu hijo, tu único."}

GEN:relacion{origen:"Dios"|destino:"Abraham"|tipo:"prueba"|capitulo:22}
GEN:relacion{origen:"Abraham"|destino:"Isaac"|tipo:"ofrece"|capitulo:22}

