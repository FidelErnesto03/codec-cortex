# ============================================
# CAPÍTULO 6: LA MALDAD Y EL DILUVIO
# ============================================

$6: LA MALDAD Y EL DILUVIO:DATA

GEN:resumen{capitulo:6,titulo:"La corrupción de la humanidad",esencia:"La maldad humana es grande, Dios decide enviar el diluvio, pero halla gracia en Noé."}

GEN:evento{nombre:"Corrupción de la tierra",capitulo:6,dia:null,accion:"Los hijos de Dios tomaron mujeres",resultado:"Nefilim y maldad creciente"}
GEN:evento{nombre:"Decisión del diluvio",capitulo:6,dia:null,accion:"Dios se arrepiente de haber hecho al hombre",resultado:"Dios decide destruir toda carne"}
GEN:evento{nombre:"Construcción del arca",capitulo:6,dia:null,accion:"Dios ordena a Noé construir un arca",resultado:"Noé obedece y construye el arca"}

GEN:personaje{nombre:"Noé",edad:600,vida:950,descendencia:"Sem, Cam, Jafet",muerte:950}

GEN:pacto{nombre:"Noé",partes:"Dios y Noé",condicion:"Construir el arca",promesa:"Preservación del diluvio",capitulo:6}

GEN:versiculo{id:"6.5",capitulo:6,verso:5,texto:"Y vio Jehová que la maldad de los hombres era mucha en la tierra, y que todo designio de los pensamientos del corazón de ellos era de continuo solamente el mal."}
GEN:versiculo{id:"6.8",capitulo:6,verso:8,texto:"Pero Noé halló gracia ante los ojos de Jehová."}
GEN:versiculo{id:"6.9",capitulo:6,verso:9,texto:"Estas son las generaciones de Noé: varón justo y perfecto era Noé en sus generaciones; con Dios caminó Noé."}
GEN:versiculo{id:"6.14",capitulo:6,verso:14,texto:"Hazte un arca de madera de gofer; harás aposentos en el arca, y la calafatearás con brea por dentro y por fuera."}

GEN:relacion{origen:"Dios"|destino:"Noé"|tipo:"gracia"|capitulo:6}
GEN:relacion{origen:"Dios"|destino:"Humanidad"|tipo:"maldice"|capitulo:6}

# ============================================
# CAPÍTULO 7: EL DILUVIO
# ============================================

$7: EL DILUVIO:DATA

GEN:resumen{capitulo:7,titulo:"El juicio de las aguas",esencia:"Noé y los animales entran en el arca, y el diluvio cubre toda la tierra."}

GEN:evento{nombre:"Entrada al arca",capitulo:7,dia:null,accion:"Noé, su familia y los animales entran",resultado:"Jehová cierra la puerta"}
GEN:evento{nombre:"Lluvia y cataclismo",capitulo:7,dia:null,accion:"Lluvia 40 días y 40 noches",resultado:"Agua cubre toda la tierra"}
GEN:evento{nombre:"Destrucción",capitulo:7,dia:null,accion:"Muere todo ser viviente",resultado:"Solo Noé y los que están con él en el arca sobreviven"}

GEN:medida{valor:40|unidad:"días"|contexto:"lluvia"}
GEN:medida{valor:150|unidad:"días"|contexto:"dominaron las aguas sobre la tierra"}

GEN:versiculo{id:"7.1",capitulo:7,verso:1,texto:"Y Jehová dijo a Noé: Entra tú y toda tu casa en el arca; porque a ti he visto justo delante de mí en esta generación."}
GEN:versiculo{id:"7.11",capitulo:7,verso:11,texto:"El año seiscientos de la vida de Noé, en el mes segundo, a los diecisiete días del mes, aquel día fueron rotas todas las fuentes del gran abismo, y las cataratas de los cielos fueron abiertas."}
GEN:versiculo{id:"7.23",capitulo:7,verso:23,texto:"Y fue destruido todo ser que existía sobre la faz de la tierra..."}

GEN:relacion{origen:"Dios"|destino:"Noé"|tipo:"guarda"|capitulo:7}

# ============================================
# CAPÍTULO 8: EL RETIRO DE LAS AGUAS
# ============================================

$8: EL RETIRO DE LAS AGUAS:DATA

GEN:resumen{capitulo:8,titulo:"El nuevo comienzo",esencia:"Las aguas se retiran, Noé envía un cuervo y una paloma, y la tierra vuelve a estar seca."}

GEN:evento{nombre:"Envío de la paloma",capitulo:8,dia:null,accion:"Noé envía una paloma",resultado:"Vuelve con rama de olivo"}
GEN:evento{nombre:"Salida del arca",capitulo:8,dia:null,accion:"Dios ordena salir del arca",resultado:"Noé construye un altar y ofrece sacrificio"}

GEN:versiculo{id:"8.11",capitulo:8,verso:11,texto:"Y la paloma volvió a él a la hora de la tarde; y he aquí que traía una hoja de olivo en el pico; y entendió Noé que las aguas se habían retirado de sobre la tierra."}
GEN:versiculo{id:"8.22",capitulo:8,verso:22,texto:"Mientras la tierra permanezca, no cesarán la sementera y la siega, el frío y el calor, el verano y el invierno, y el día y la noche."}

GEN:relacion{origen:"Dios"|destino:"Noé"|tipo:"promete"|capitulo:8}

