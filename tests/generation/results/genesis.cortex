GEN:evento{nombre:"Esaú llora",capitulo:27,dia:null,accion:"Esaú descubre el engaño",resultado:"Jura matar a Jacob"}

GEN:profecia{nombre:"Bendición de Jacob",capitulo:27,destinatario:"Jacob",texto:"Dios te dé del rocío del cielo, y de las grosuras de la tierra, y abundancia de trigo y de vino."}
GEN:profecia{nombre:"Bendición de Esaú",capitulo:27,destinatario:"Esaú",texto:"He aquí, tu habitación será en grosuras de la tierra, y del rocío de los cielos de arriba."}

GEN:versiculo{id:"27.1",capitulo:27,verso:1,texto:"Y aconteció que cuando Isaac envejeció, y sus ojos se oscurecieron, llamó a Esaú su hijo mayor..."}
GEN:versiculo{id:"27.36",capitulo:27,verso:36,texto:"Y Esaú respondió: Bien llamaron su nombre Jacob, porque ya me ha suplantado dos veces..."}

