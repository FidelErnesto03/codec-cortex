GEN:personaje{nombre:"Potifar",edad:null,vida:null,descendencia:null,muerte:null}

GEN:versiculo{id:"39.1",capitulo:39,verso:1,texto:"Llevado, pues, José a Egipto, Potifar, oficial de Faraón, capitán de la guardia, varón egipcio, lo compró..."}
GEN:versiculo{id:"39.9",capitulo:39,verso:9,texto:"No hay otro mayor que yo en esta casa, y ninguna cosa me ha reservado sino a ti, por cuanto tú eres su mujer; ¿cómo, pues, haría yo este gran mal, y pecaría contra Dios?"}
GEN:versiculo{id:"39.20",capitulo:39,verso:20,texto:"Y tomó su amo a José, y lo puso en la cárcel..."}

