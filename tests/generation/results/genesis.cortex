# CAPÍTULO 41: EL SUEÑO DE FARAÓN
# ============================================

$41: EL SUEÑO DE FARAÓN:FLOW

GEN:resumen{capitulo:41,titulo:"José ante Faraón",esencia:"Faraón tiene sueños, José los interpreta, es nombrado gobernador de Egipto."}

GEN:evento{nombre:"Sueños de Faraón",capitulo:41,dia:null,accion:"Faraón sueña con vacas y espigas",resultado:"José interpreta"}
GEN:evento{nombre:"Nombramiento",capitulo:41,dia:null,accion:"Faraón nombra a José gobernador",resultado:"Preparación para la hambruna"}
GEN:evento{nombre:"Familia",capitulo:41,dia:null,accion:"José tiene hijos",resultado:"Manasés y Efraín"}

GEN:personaje{nombre:"José",edad:30,vida:110,descendencia:"Efraín, Manasés",muerte:110}
GEN:personaje{nombre:"Faraón",edad:null,vida:null,descendencia:null,muerte:null}

GEN:versiculo{id:"41.1",capitulo:41,verso:1,texto:"Y sucedió que al cabo de dos años tuvo Faraón un sueño..."}
GEN:versiculo{id:"41.16",capitulo:41,verso:16,texto:"Respondió José a Faraón, diciendo: No está en mí; Dios será el que dé respuesta de paz a Faraón."}
GEN:versiculo{id:"41.41",capitulo:41,verso:41,texto:"Y dijo Faraón a José: He aquí, yo te he puesto sobre toda la tierra de Egipto."}
GEN:versiculo{id:"41.51",capitulo:41,verso:51,texto:"Y llamó José el nombre del primogénito Manasés; porque dijo: Dios me hizo olvidar todo mi trabajo, y toda la casa de mi padre."}
GEN:versiculo{id:"41.52",capitulo:41,verso:52,texto:"Y al segundo llamó Efraín; porque dijo: Dios me hizo fructificar en la tierra de mi aflicción."}

GEN:relacion{origen:"Dios"|destino:"José"|tipo:"revela"|capitulo:41}
GEN:relacion{origen:"Faraón"|destino:"José"|tipo:"exalta"|capitulo:41}

