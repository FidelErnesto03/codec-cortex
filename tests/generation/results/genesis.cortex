$0:KERNEL
$0:format{cortex:0.1,encoding:UTF-8,language:es,type:corpus}

# ============================================
# GLOSARIO - SIGLAS PARA EL GÉNESIS
# ============================================

GEN:versiculo{type:cuerpo,weight:H,fields:"id:text|capitulo:number|verso:number|texto:text",focus:texto,schema:prose,desc:"Texto del versículo bíblico"}

GEN:resumen{type:cuerpo,weight:M,fields:"capitulo:number|titulo:text|esencia:text",focus:esencia,schema:prose,desc:"Resumen temático del capítulo"}

GEN:evento{type:attrs,weight:H,fields:"nombre:text|capitulo:number|dia:number|accion:text|resultado:text",focus:nombre,schema:table,desc:"Evento mayor en la narrativa"}

GEN:personaje{type:attrs,weight:H,fields:"nombre:text|edad:number|vida:number|descendencia:text|muerte:number",focus:nombre,schema:table,desc:"Personaje con datos biográficos"}

GEN:genealogia{type:attrs-pos,weight:M,fields:"padre:text|hijo:text|generacion:number|edad_padre:number",pos:"0|1|2|3",focus:hijo,schema:list,desc:"Linea genealogica con edades"}

GEN:relacion{type:relacion,weight:M,fields:"origen:text|destino:text|tipo:text|capitulo:number",focus:tipo,schema:diagram,desc:"Relación entre personajes o elementos"}

GEN:pacto{type:attrs,weight:H,fields:"nombre:text|partes:text|condicion:text|promesa:text|capitulo:number",focus:nombre,schema:table,desc:"Pacto o alianza divina"}

GEN:profecia{type:cuerpo,weight:H,fields:"nombre:text|capitulo:number|destinatario:text|texto:text",focus:texto,schema:prose,desc:"Profecía o bendición"}

GEN:lugar{type:attrs,weight:M,fields:"nombre:text|tipo:text|significado:text|capitulo:number",focus:nombre,schema:table,desc:"Lugar geográfico importante"}

GEN:medida{type:attrs-pos,weight:B,fields:"valor:number|unidad:text|contexto:text",focus:valor,schema:list,desc:"Medidas, edades, distancias"}

# ============================================
# MICROTOKENS Y ENUMS
# ============================================

$0:enum_dia{values:1|2|3|4|5|6|7}
$0:enum_relacion{values:padre|hijo|esposo|hermano|siervo|creador|bendice|maldice|pacta}
$0:enum_tipo_lugar{values:ciudad|pozo|monte|valle|rio|mar|altar|tienda}
$0:enum_pacto{values:noe|abraham|isaac|jacob|david}

# ============================================
# CAPÍTULO 1: LA CREACIÓN
# ============================================

$1: LA CREACIÓN DEL MUNDO:DATA

GEN:resumen{capitulo:1,titulo:"Los siete días",esencia:"Dios crea los cielos, la tierra y todo lo que existe en seis días, y descansa el séptimo."}

GEN:evento{nombre:"Creación de la luz",capitulo:1,dia:1,accion:"Dijo Dios: Sea la luz",resultado:"Separó la luz de las tinieblas"}
GEN:evento{nombre:"Creación del firmamento",capitulo:1,dia:2,accion:"Dijo Dios: Haya un firmamento",resultado:"Separó las aguas de las aguas"}
GEN:evento{nombre:"Creación de tierra y vegetación",capitulo:1,dia:3,accion:"Dijo Dios: Produzca la tierra",resultado:"Vegetación con semilla"}
GEN:evento{nombre:"Creación de lumbreras",capitulo:1,dia:4,accion:"Dijo Dios: Haya lumbreras",resultado:"Sol, luna y estrellas"}
GEN:evento{nombre:"Creación de animales acuáticos y aves",capitulo:1,dia:5,accion:"Dijo Dios: Produzcan las aguas",resultado:"Peces y aves según su especie"}
GEN:evento{nombre:"Creación de animales terrestres y hombre",capitulo:1,dia:6,accion:"Dijo Dios: Hagamos al hombre",resultado:"Hombre y mujer a imagen de Dios"}
GEN:evento{nombre:"Día de reposo",capitulo:1,dia:7,accion:"Dios reposó",resultado:"Bendijo y santificó el séptimo día"}

GEN:versiculo{id:"1.1",capitulo:1,verso:1,texto:"En el principio creó Dios los cielos y la tierra."}
GEN:versiculo{id:"1.26",capitulo:1,verso:26,texto:"Entonces dijo Dios: Hagamos al hombre a nuestra imagen, conforme a nuestra semejanza..."}
GEN:versiculo{id:"1.27",capitulo:1,verso:27,texto:"Y creó Dios al hombre a su imagen, a imagen de Dios lo creó; varón y hembra los creó."}

GEN:relacion{origen:"Dios"|destino:"Luz"|tipo:"crea"|capitulo:1}
GEN:relacion{origen:"Dios"|destino:"Hombre"|tipo:"crea"|capitulo:1}
GEN:relacion{origen:"Dios"|destino:"Mujer"|tipo:"crea"|capitulo:1}

# ============================================
# CAPÍTULO 2: EL HUERTO DEL EDÉN
# ============================================

$2: EL HUERTO DEL EDÉN:DATA

GEN:resumen{capitulo:2,titulo:"La creación del hombre y la mujer",esencia:"Dios forma al hombre del polvo, planta el huerto del Edén, y crea a la mujer como ayuda idónea."}

GEN:evento{nombre:"Formación del hombre",capitulo:2,dia:null,accion:"Dios formó al hombre del polvo de la tierra",resultado:"Hombre con aliento de vida"}
GEN:evento{nombre:"Huerto del Edén",capitulo:2,dia:null,accion:"Dios plantó un huerto en Edén",resultado:"Huerto con árboles y ríos"}
GEN:evento{nombre:"Formación de la mujer",capitulo:2,dia:null,accion:"Dios hizo una mujer de la costilla",resultado:"Mujer como ayuda idónea"}

GEN:lugar{nombre:"Edén",tipo:"huerto",significado:"Delicia",capitulo:2}
GEN:lugar{nombre:"Pishón",tipo:"rio",significado:"El que fluye",capitulo:2}
GEN:lugar{nombre:"Guihón",tipo:"rio",significado:"Torrente",capitulo:2}
GEN:lugar{nombre:"Tigris",tipo:"rio",significado:"Rápido",capitulo:2}
GEN:lugar{nombre:"Éufrates",tipo:"rio",significado:"Fructífero",capitulo:2}

GEN:personaje{nombre:"Adán",edad:null,vida:930,descendencia:"Caín, Abel, Set",muerte:null}

GEN:versiculo{id:"2.7",capitulo:2,verso:7,texto:"Entonces Jehová Dios formó al hombre del polvo de la tierra, y sopló en su nariz aliento de vida, y fue el hombre un alma viviente."}
GEN:versiculo{id:"2.18",capitulo:2,verso:18,texto:"Y dijo Jehová Dios: No es bueno que el hombre esté solo; le haré ayuda idónea para él."}
GEN:versiculo{id:"2.24",capitulo:2,verso:24,texto:"Por tanto, dejará el hombre a su padre y a su madre, y se unirá a su mujer, y serán una sola carne."}

GEN:relacion{origen:"Dios"|destino:"Adán"|tipo:"creador"|capitulo:2}
GEN:relacion{origen:"Dios"|destino:"Eva"|tipo:"creador"|capitulo:2}
GEN:relacion{origen:"Adán"|destino:"Eva"|tipo:"esposo"|capitulo:2}

# ============================================
# CAPÍTULO 3: LA CAÍDA
# ============================================

$3: LA CAÍDA DEL HOMBRE:DATA

GEN:resumen{capitulo:3,titulo:"El pecado y sus consecuencias",esencia:"La serpiente tienta a Eva, Adán y Eva comen del fruto prohibido, son expulsados del Edén."}

GEN:evento{nombre:"Tentación",capitulo:3,dia:null,accion:"La serpiente engaña a Eva",resultado:"Eva come del fruto y da a Adán"}
GEN:evento{nombre:"Desobediencia",capitulo:3,dia:null,accion:"Adán y Eva comen del fruto prohibido",resultado:"Se abren los ojos y conocen el bien y el mal"}
GEN:evento{nombre:"Juicio",capitulo:3,dia:null,accion:"Dios juzga a la serpiente, Eva y Adán",resultado:"Maldición y expulsión del Edén"}
GEN:evento{nombre:"Expulsión",capitulo:3,dia:null,accion:"Dios los echa del huerto",resultado:"Querubines y espada ardiente"}

GEN:personaje{nombre:"Adán",edad:null,vida:930,descendencia:"Caín, Abel, Set",muerte:null}
GEN:personaje{nombre:"Eva",edad:null,vida:null,descendencia:"Caín, Abel, Set",muerte:null}
GEN:personaje{nombre:"Serpiente",edad:null,vida:null,descendencia:null,muerte:null}

GEN:profecia{nombre:"Enemistad",capitulo:3,destinatario:"Serpiente",texto:"Pondré enemistad entre ti y la mujer, y entre tu simiente y la suya; esta te herirá en la cabeza, y tú le herirás en el calcañar."}

GEN:versiculo{id:"3.1",capitulo:3,verso:1,texto:"Pero la serpiente era astuta, más que todos los animales del campo que Jehová Dios había hecho..."}
GEN:versiculo{id:"3.15",capitulo:3,verso:15,texto:"Y pondré enemistad entre ti y la mujer, y entre tu simiente y la suya; esta te herirá en la cabeza, y tú le herirás en el calcañar."}
GEN:versiculo{id:"3.19",capitulo:3,verso:19,texto:"Con el sudor de tu rostro comerás el pan hasta que vuelvas a la tierra, porque de ella fuiste tomado; pues polvo eres, y al polvo volverás."}

GEN:relacion{origen:"Serpiente"|destino:"Eva"|tipo:"engaña"|capitulo:3}
GEN:relacion{origen:"Eva"|destino:"Adán"|tipo:"da"|capitulo:3}
GEN:relacion{origen:"Dios"|destino:"Adán"|tipo:"maldice"|capitulo:3}
GEN:relacion{origen:"Dios"|destino:"Eva"|tipo:"maldice"|capitulo:3}
GEN:relacion{origen:"Dios"|destino:"Serpiente"|tipo:"maldice"|capitulo:3}

# ============================================
# CAPÍTULO 4: CAÍN Y ABEL
# ============================================

$4: CAÍN Y ABEL:DATA

GEN:resumen{capitulo:4,titulo:"El primer asesinato",esencia:"Caín mata a su hermano Abel por celos, es maldecido y se convierte en errante."}

GEN:evento{nombre:"Ofrenda rechazada",capitulo:4,dia:null,accion:"Caín ofrece frutos, Abel ofrece primogénitos",resultado:"Dios acepta la de Abel y rechaza la de Caín"}
GEN:evento{nombre:"Asesinato",capitulo:4,dia:null,accion:"Caín mata a Abel en el campo",resultado:"La sangre de Abel clama desde la tierra"}
GEN:evento{nombre:"Maldición de Caín",capitulo:4,dia:null,accion:"Dios maldice a Caín",resultado:"Caín es errante y fugitivo"}
GEN:evento{nombre:"Marca de Caín",capitulo:4,dia:null,accion:"Dios pone una marca a Caín",resultado:"Protección para que no lo maten"}

GEN:personaje{nombre:"Caín",edad:null,vida:null,descendencia:"Enoch",muerte:null}
GEN:personaje{nombre:"Abel",edad:null,vida:null,descendencia:null,muerte:null}
GEN:personaje{nombre:"Adán",edad:null,vida:930,descendencia:"Caín, Abel, Set",muerte:null}
GEN:personaje{nombre:"Eva",edad:null,vida:null,descendencia:"Caín, Abel, Set",muerte:null}

GEN:versiculo{id:"4.3",capitulo:4,verso:3,texto:"Y aconteció andando el tiempo, que Caín trajo del fruto de la tierra una ofrenda a Jehová."}
GEN:versiculo{id:"4.4",capitulo:4,verso:4,texto:"Y Abel trajo también de los primogénitos de sus ovejas, y de la grosura de ellas. Y Jehová miró con agrado a Abel y a su ofrenda."}
GEN:versiculo{id:"4.8",capitulo:4,verso:8,texto:"Y dijo Caín a su hermano Abel: Salgamos al campo. Y aconteció que estando ellos en el campo, Caín se levantó contra su hermano Abel, y lo mató."}
GEN:versiculo{id:"4.10",capitulo:4,verso:10,texto:"Y Dios le dijo: ¿Qué has hecho? La voz de la sangre de tu hermano clama a mí desde la tierra."}

GEN:relacion{origen:"Caín"|destino:"Abel"|tipo:"hermano"|capitulo:4}
GEN:relacion{origen:"Caín"|destino:"Abel"|tipo:"mata"|capitulo:4}
GEN:relacion{origen:"Dios"|destino:"Caín"|tipo:"maldice"|capitulo:4}

