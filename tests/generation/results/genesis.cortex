GEN:personaje{nombre:"Abraham",edad:null,vida:175,descendencia:"Isaac, Ismael",muerte:175}
GEN:personaje{nombre:"Esaú",edad:null,vida:null,descendencia:"Edomitas",muerte:null}
GEN:personaje{nombre:"Jacob",edad:null,vida:147,descendencia:"12 hijos",muerte:147}

GEN:versiculo{id:"25.21",capitulo:25,verso:21,texto:"E Isaac oró a Jehová por su mujer, que era estéril; y Jehová le respondió, y concibió Rebeca su mujer."}
GEN:versiculo{id:"25.23",capitulo:25,verso:23,texto:"Y Jehová le dijo: Dos naciones hay en tu seno, y dos pueblos serán divididos desde tus entrañas; el un pueblo será más fuerte que el otro pueblo, y el mayor servirá al menor."}
GEN:versiculo{id:"25.34",capitulo:25,verso:34,texto:"Entonces Jacob dio a Esaú pan y del guisado de lentejas; y él comió y bebió, y se levantó y se fue. Así menospreció Esaú la primogenitura."}

GEN:relacion{origen:"Isaac"|destino:"Jacob"|tipo:"padre"|capitulo:25}
GEN:relacion{origen:"Isaac"|destino:"Esaú"|tipo:"padre"|capitulo:25}
GEN:relacion{origen:"Jacob"|destino:"Esaú"|tipo:"hermano"|capitulo:25}
GEN:relacion{origen:"Jacob"|destino:"Esaú"|tipo:"suplanta"|capitulo:25}

