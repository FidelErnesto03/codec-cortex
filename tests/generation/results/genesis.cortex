# ============================================

$12: EL LLAMADO DE ABRAHAM:DATA

GEN:resumen{capitulo:12,titulo:"La promesa a Abraham",esencia:"Dios llama a Abraham, le promete una gran nación y bendición, y él obedece."}

GEN:evento{nombre:"Llamado de Abraham",capitulo:12,dia:null,accion:"Dios llama a Abraham a salir de Ur",resultado:"Abraham obedece y va a Canaán"}
GEN:evento{nombre:"Hambre en Canaán",capitulo:12,dia:null,accion:"Abraham baja a Egipto",resultado:"Faraón toma a Sara, Dios envía plagas"}

GEN:personaje{nombre:"Abraham",edad:75,vida:175,descendencia:"Isaac, Ismael",muerte:175}
