# ============================================

$9: EL PACTO CON NOÉ:DATA

GEN:resumen{capitulo:9,titulo:"El arcoíris y la bendición",esencia:"Dios establece su pacto con Noé, bendice a sus hijos, y maldice a Canaán."}

GEN:evento{nombre:"Bendición",capitulo:9,dia:null,accion:"Dios bendice a Noé y sus hijos",resultado:"Fructificad y multiplicaos"}
GEN:evento{nombre:"Pacto del arcoíris",capitulo:9,dia:null,accion:"Dios pone el arcoíris",resultado:"Señal del pacto con toda carne"}
GEN:evento{nombre:"Maldición de Canaán",capitulo:9,dia:null,accion:"Noé maldice a Canaán",resultado:"Siervo de siervos será"}

GEN:pacto{nombre:"Noé",partes:"Dios y toda carne",condicion:"No destruir toda carne",promesa:"Arcoíris como señal",capitulo:9}

