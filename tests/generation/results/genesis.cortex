GEN:personaje{nombre:"Abraham",edad:99,vida:175,descendencia:"Isaac, Ismael",muerte:175}
GEN:personaje{nombre:"Sara",edad:89,vida:127,descendencia:"Isaac",muerte:127}

GEN:versiculo{id:"17.1",capitulo:17,verso:1,texto:"Yo soy el Dios Todopoderoso; anda delante de mí y sé perfecto."}
GEN:versiculo{id:"17.5",capitulo:17,verso:5,texto:"Y no se llamará más tu nombre Abram, sino que será tu nombre Abraham, porque te he puesto por padre de muchedumbre de gentes."}
GEN:versiculo{id:"17.7",capitulo:17,verso:7,texto:"Estableceré mi pacto entre mí y ti, y tu descendencia después de ti en sus generaciones, por pacto perpetuo..."}
GEN:versiculo{id:"17.15",capitulo:17,verso:15,texto:"A Sarai tu mujer no la llamarás Sarai, sino que Sara será su nombre."}

# ============================================
# CAPÍTULO 18: LA VISITA DE LOS ÁNGELES
# ============================================

$18: LA VISITA DE LOS ÁNGELES:DATA

GEN:resumen{capitulo:18,titulo:"La visita y la intercesión",esencia:"Tres varones visitan a Abraham, le anuncian el nacimiento de Isaac, y Abraham intercede por Sodoma."}

GEN:evento{nombre:"Anuncio de Isaac",capitulo:18,dia:null,accion:"Los ángeles anuncian",resultado:"Sara se ríe"}
GEN:evento{nombre:"Intercesión",capitulo:18,dia:null,accion:"Abraham negocia por Sodoma",resultado:"Dios acepta si hay 10 justos"}

GEN:versiculo{id:"18.10",capitulo:18,verso:10,texto:"Volveré ciertamente a ti según el tiempo de la vida; y he aquí que Sara tu mujer tendrá un hijo."}
GEN:versiculo{id:"18.12",capitulo:18,verso:12,texto:"Se rió Sara para sus adentros, diciendo: ¿Después que he envejecido tendré deleite, siendo también mi señor ya viejo?"}
GEN:versiculo{id:"18.14",capitulo:18,verso:14,texto:"¿Hay para Dios alguna cosa difícil? Al tiempo señalado volveré a ti, según el tiempo de la vida, y Sara tendrá un hijo."}
GEN:versiculo{id:"18.32",capitulo:18,verso:32,texto:"No se enoje ahora mi Señor, y hablaré solamente una vez: ¿Quizás se hallarán allí diez? Y respondió: No la destruiré por causa de los diez."}

GEN:relacion{origen:"Abraham"|destino:"Dios"|tipo:"intercede"|capitulo:18}

