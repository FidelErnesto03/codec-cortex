GEN:evento{nombre:"Simeón prisionero",capitulo:42,dia:null,accion:"José retiene a Simeón",resultado:"Deben traer a Benjamín"}

GEN:personaje{nombre:"Simeón",edad:null,vida:null,descendencia:null,muerte:null}
GEN:personaje{nombre:"Benjamín",edad:null,vida:null,descendencia:null,muerte:null}

GEN:versiculo{id:"42.8",capitulo:42,verso:8,texto:"Y José reconoció a sus hermanos, pero ellos no le reconocieron."}
GEN:versiculo{id:"42.24",capitulo:42,verso:24,texto:"Y se volvió José de ellos, y lloró..."}

GEN:relacion{origen:"José"|destino:"Hermanos"|tipo:"prueba"|capitulo:42}

