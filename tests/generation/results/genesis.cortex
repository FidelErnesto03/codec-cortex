GEN:versiculo{id:"26.3",capitulo:26,verso:3,texto:"Habitó, pues, Isaac en Gerar."}
GEN:versiculo{id:"26.24",capitulo:26,verso:24,texto:"Y se le apareció Jehová aquella noche, y le dijo: Yo soy el Dios de Abraham tu padre; no temas, porque yo estoy contigo, y te bendeciré..."}

# ============================================
# CAPÍTULO 27: LA BENDICIÓN DE JACOB
# ============================================

$27: LA BENDICIÓN DE JACOB:FLOW

GEN:resumen{capitulo:27,titulo:"El engaño de Jacob",esencia:"Rebeca ayuda a Jacob a engañar a Isaac para recibir la bendición de la primogenitura."}

