# ============================================
# CAPÍTULO 11: LA TORRE DE BABEL
# ============================================

$11: LA TORRE DE BABEL:DATA

GEN:resumen{capitulo:11,titulo:"La torre y la confusión",esencia:"Los hombres construyen una torre para llegar al cielo, Dios confunde sus lenguas y los dispersa."}

GEN:evento{nombre:"Construcción de Babel",capitulo:11,dia:null,accion:"Los hombres edifican una torre",resultado:"Dios confunde el lenguaje"}
GEN:evento{nombre:"Dispersión",capitulo:11,dia:null,accion:"Dios los esparce por la tierra",resultado:"No terminan la torre"}

GEN:lugar{nombre:"Babel",tipo:"ciudad",significado:"Confusión",capitulo:11}

GEN:versiculo{id:"11.1",capitulo:11,verso:1,texto:"Tenía entonces toda la tierra una sola lengua y unas mismas palabras."}
GEN:versiculo{id:"11.4",capitulo:11,verso:4,texto:"Y dijeron: Vamos, edifiquémonos una ciudad y una torre, cuyo remate llegue al cielo; y hagámonos un nombre, para que no seamos esparcidos sobre la faz de toda la tierra."}
GEN:versiculo{id:"11.9",capitulo:11,verso:9,texto:"Por esto fue llamado el nombre de ella Babel, porque allí confundió Jehová el lenguaje de toda la tierra, y desde allí los esparció Jehová sobre la faz de toda la tierra."}

