GEN:pacto{nombre:"Abraham",partes:"Dios y Abraham",condicion:"Salir de su tierra",promesa:"Tierra, descendencia y bendición",capitulo:12}

GEN:versiculo{id:"12.1",capitulo:12,verso:1,texto:"Jehová había dicho a Abram: Vete de tu tierra, y de tu parentela, y de la casa de tu padre, a la tierra que te mostraré."}
GEN:versiculo{id:"12.2",capitulo:12,verso:2,texto:"Y haré de ti una nación grande, y te bendeciré, y engrandeceré tu nombre, y serás bendición."}
GEN:versiculo{id:"12.3",capitulo:12,verso:3,texto:"Bendeciré a los que te bendijeren, y a los que te maldijeren maldeciré; y serán benditas en ti todas las familias de la tierra."}
GEN:versiculo{id:"12.4",capitulo:12,verso:4,texto:"Y se fue Abram, como Jehová le dijo."}

GEN:relacion{origen:"Dios"|destino:"Abraham"|tipo:"llama"|capitulo:12}
GEN:relacion{origen:"Abraham"|destino:"Sara"|tipo:"esposo"|capitulo:12}
GEN:relacion{origen:"Abraham"|destino:"Lot"|tipo:"sobrino"|capitulo:12}

