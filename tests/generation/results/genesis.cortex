# ============================================
# CAPÍTULO 22: LA PRUEBA DE ABRAHAM
# ============================================

$22: LA PRUEBA DE ABRAHAM:FLOW

GEN:resumen{capitulo:22,titulo:"El sacrificio de Isaac",esencia:"Dios prueba a Abraham pidiéndole sacrificar a Isaac, Abraham obedece, Dios provee un carnero."}

GEN:evento{nombre:"Prueba",capitulo:22,dia:null,accion:"Dios pide a Isaac como holocausto",resultado:"Abraham obedece"}
