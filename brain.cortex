KNW:priority_pack{topic:"Priority Pack P0-P5", content:"P0: FCS/OBJ/CNST/STP. P1: WRK/AUD/RSK/NXT. P2: CLAIM/LIM/KNW:active/LNG:critical. load_order: P0->P5. degrade_order: P5->P1", status:"current"}
KNW:canonical_stack{topic:"CODEC-CORTEX Canonical Stack", content:"order: Universal Skill -> .cortex contextual memory -> HCORTEX human view -> deterministic codec planned -> memory runtime future -> enterprise MCP future", status:"current"}
KNW:release{topic:"Release History", content:"version: 0.2.3, tag: v0.2.3, previous: v0.2.2, next: 0.3.0, type: PATCH (HCORTEX views sync + docs alignment + recovery REs drafted)", status:"current"}
KNW:paths{topic:"Project Paths", content:"repo: ~/Projects/workspace/CODEC-CORTEX/codec-cortex/, public: github.com/FidelErnesto03/codec-cortex, cli: cli/", status:"current"}
KNW:compression_rules{topic:"HCORTEX Compression Rules", content:"hcortex_compact: !hcortex_profile, !hcortex_source, !hcortex_multi, !hcortex_expand, !hcortex_order. survive_rules: !survive_priority, !survive_degrade, !survive_status. filter: !p5_filter", status:"current"}
KNW:skill_architecture_knowledge{topic:"SKILL Architecture Knowledge", content:"6-layer stack: Skill->.cortex->HCORTEX->Codec->Runtime->MCP. .cortex tiene survive P0-P5 + attrs-pos + 10-step HCORTEX", status:"current"}
KNW:degradation_flow_knowledge{topic:"Degradation Flow Knowledge", content:"Degradacion FULL->MIN: drop P5->P4->P3 en WORK, keep KNW:LNG activos, solo P0 en MIN. CNST:blocking nunca desaparece. Bidireccional en recuperacion", status:"current"}
KNW:benchmark_v1{topic:"Benchmark v1.0.0", content:"Formal scientific benchmark. 11 metodos x 11 escenarios x 40 tareas = 4,840 runs. Corpus L2: 10 dominios x 5 formatos. 15 metricas canonicas. Hallazgos: CPP preserva 100% P0 (BCFNR=0, UCFPR=0), MRD=+2.16, QDD=-3.95. CODEC v0.3.0 + CLI v1.1.9.", status:"current"}
DIAG:skill_architecture{
caption:"CODEC-CORTEX Canonical Stack v0.2.3",
source:"SKILL.cortex $6",
@startuml
title CODEC-CORTEX — Arquitectura de compresion y supervivencia
rectangle "Universal Skill\n(current)" as skill
rectangle ".cortex\n(structured memory)" as cortex
rectangle "HCORTEX\n(human view)" as hcortex
rectangle "Codec\n(planned)" as codec
rectangle "Runtime\n(future)" as runtime
rectangle "Enterprise MCP\n(future)" as mcp
skill --> cortex
cortex --> hcortex
cortex --> codec
codec --> runtime
runtime --> mcp
note right of cortex
  survive: P0->P5
  attrs-pos format
  10-step HCORTEX render
end note
@enduml
}
DIAG:survival_degradation{
caption:"Flujo de degradacion por presupuesto",
source:"RE-015 §7",
@startuml
title Degradacion: FULL -> MIN
state "FULL\nP0-P5\n(unlimited)" as FULL
state "WORK\nP0-P2\n(~3000t)" as WORK
state "RECOVERY\nP0+P1\n(~1000t)" as RECOVERY
state "MIN\nP0 only\n(~300t)" as MIN
FULL --> WORK : budget down\ndrop P5->P4->P3
WORK --> RECOVERY : budget down\nkeep KNW:active, LNG:critical
RECOVERY --> MIN : budget down\nP0 only, CNST:blocking always
MIN --> RECOVERY : budget up
RECOVERY --> WORK : budget up
WORK --> FULL : budget up
@enduml
}

$6: RISKS

RSK:premature_release{risk:"Crear release v0.3.0-spec antes de tener parser o benchmark automatizado", impact:"medium", mitigation:"v0.3.0 como MINOR legitimo: agrega CLI funcional con 222 tests. Survival Core es specification draft documentado como tal", status:"current", survive:"recovery"}
RSK:profile_ambiguity{risk:"Perfiles conceptuales sin listas cerradas pueden ser ambiguos para agentes", impact:"low", mitigation:"Los perfiles son criterios de prioridad, no inventarios. Se refinan con benchmarks", status:"current", survive:"work"}
RSK:glossary_divergence{risk:"brain.cortex y SKILL.cortex $0 pueden divergir nuevamente con nuevos sigilos", impact:"medium", mitigation:"cortex verify compara $0 de cada .cortex contra el glosario canonico de SKILL.cortex. RE-004 establece SKILL.cortex $0 como fuente canonica", status:"current", survive:"recovery"}

