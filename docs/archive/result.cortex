# -- $2: CANONICAL OUTCOME ----------------------------------------------------
AXM:direction{Universal Skill first. .cortex as contextual memory. HCORTEX as human contextual reversibility. Deterministic codec as automation phase. Enterprise MCP as future operating layer}
AXM:truth{The repository must not sound more implemented than it is}
AXM:separation{Skill, format, human view, codec, runtime and MCP are distinct layers and must not be collapsed into one claim}
AXM:reversibility{Use structural reversibility for codec roundtrip targets and contextual reversibility for HCORTEX. Do not promise literal reconstruction of every original message}
AXM:benchmark{Numeric performance claims require reproducible benchmark evidence. Without evidence, language must be target, illustrative or removed}

MAP:narrative{from:"codec-first deterministic compression protocol", to:"universal memory Skill and contextual memory protocol", status:"applied"}
MAP:claim_policy{from:"85 percent / zero LLM / 100 percent reversible public claim", to:"high-density target, deterministic planned codec, scoped structural/contextual reversibility", status:"applied"}
MAP:maturity{from:"implementation-sounding docs", to:"current/specification/planned/future status model", status:"applied"}
MAP:mcp{from:"MCP bridge may sound current", to:"future enterprise design and operating layer", status:"applied"}
MAP:examples{from:"template values could look like real state", to:"template notice, placeholders, illustrative metrics", status:"applied"}

