# -- $10: EXPECTED OUTPUTS ----------------------------------------------------

OUT:report{path:"docs/review/project-reorientation-report.md", required:true, content:["diagnosis","risk register","file-by-file recommendations","claim inventory","status inventory"]}
OUT:readme{path:"README.md", required:true, content:["problem","what it is","current stage","quick start","stack","roadmap","status","license"]}
OUT:skill{path:"skill/SKILL.md", required:true, content:["when to use","adoption directive","memory model","operations table","HCORTEX","reversibility policy","pitfalls","checklist"]}
OUT:skill_cortex{path:"skill/SKILL.cortex", required:true, content:["same canonical narrative in dense form","handler statuses","rules","pitfalls","diagrams"]}
OUT:agent_cortex{path:"skill/AGENT.cortex", required:true, content:["example identity","safe canonical memory rule","placeholders if applicable"]}
OUT:brain_cortex{path:"skill/brain.cortex", required:true, content:["template notice","placeholder values","local brain structure"]}
OUT:roadmap{path:"ROADMAP.md", required:true, content:["phases","deliverables","acceptance criteria","non-goals"]}
OUT:status{path:"STATUS.md", required:true, content:["implemented","specified","planned","future","not promised"]}
OUT:final_summary{path:"agent-output-summary.md", required:false, content:["what changed","why","remaining risks"]}

# -- $11: TESTS AND CHECKS ----------------------------------------------------

TEST:forbidden_refs{name:"external project reference scan", method:"grep repository for known forbidden names or unrelated project identifiers", expected:"zero matches"}
TEST:status_words{name:"status vocabulary scan", method:"features must include current/specification/planned/future where relevant", expected:"no ambiguous capability claims"}
TEST:readme_opening{name:"30 second reader test", method:"first 40 lines of README must explain Skill-first identity", expected:"clear without reading docs"}
TEST:roundtrip_language{name:"reversibility language scan", method:"each occurrence of reversible/reversibility must specify structural/contextual or deny textual", expected:"no generic 100% reversible claims"}
TEST:benchmark_language{name:"metrics scan", method:"numeric performance claims must be labeled measured/target/expected/illustrative", expected:"no unsupported measured claims"}
TEST:cli_language{name:"CLI command scan", method:"all cortex command examples must be current or planned", expected:"no phantom availability"}
TEST:mcp_language{name:"MCP scan", method:"mcp docs must begin with future design status", expected:"unmissable"}
TEST:template_safety{name:"example safety", method:"placeholder and template notices present in AGENT/brain examples", expected:"no fake real state"}
TEST:cross_doc_consistency{name:"term consistency", method:"compare README, SKILL, ROADMAP, STATUS", expected:"same phase model and definitions"}

# -- $12: PROPOSED README OPENING --------------------------------------------

REW:readme_opening_en{target:"README.md", mode:"replace_top", text:"CODEC-CORTEX is a universal memory Skill and contextual memory protocol for LLM/SLM agents. It helps agents organize persistent memory as structured operational context: identity, focus, objective, working state, rules, sessions, lessons, knowledge and references. Its native .cortex format is designed for dense model consumption, while HCORTEX provides a human-readable view for inspection, audit and correction. The deterministic codec, CLI, runtime and enterprise MCP bridge are planned phases, not assumptions of initial adoption"}
REW:readme_opening_es{target:"README.md or Spanish docs", mode:"reference", text:"CODEC-CORTEX es un Skill universal y protocolo de memoria contextual para agentes LLM/SLM. Ayuda a organizar la memoria persistente como contexto operativo estructurado: identidad, foco, objetivo, estado de trabajo, reglas, sesiones, lecciones, conocimiento y referencias. Su formato nativo .cortex está diseñado para consumo denso por modelos, mientras HCORTEX ofrece una vista humana para inspección, auditoría y corrección. El codec determinista, CLI, runtime y MCP empresarial son fases planificadas, no requisitos de adopción inicial"}

# -- $13: PROPOSED STATUS REGISTRY -------------------------------------------

STAT:implemented_now{items:["repository documentation structure","README initial public entry","skill/SKILL.md specification draft","skill/SKILL.cortex dense skill draft","skill/AGENT.cortex example","skill/brain.cortex template","Spanish and English reference documents"]}
STAT:specified{items:["cortex sections and sigils","HCORTEX concept","adoption model","parser design","verify concept","MCP handler map design"]}
STAT:planned_next{items:["deterministic parser","AST representation","encode/decode","structural verify","HCORTEX renderer","minimal CLI","tests"]}
STAT:future{items:["memory runtime","automatic consolidation","promotion/decay engine","enterprise MCP server","audit and governance layer"]}
STAT:not_promised{items:["literal reconstruction of every original message","measured 85% token reduction without benchmarks","guaranteed recall improvement","production-ready enterprise MCP today","universal performance across all models"]}

# -- $14: QUALITY RUBRIC ------------------------------------------------------

CHK:clarity{question:"Can a new reader explain what CODEC-CORTEX is in one sentence?", pass:"yes, universal memory Skill and contextual memory protocol for LLM/SLM agents"}
CHK:maturity{question:"Can a new reader distinguish current from planned?", pass:"yes, STATUS and README make it explicit"}
CHK:technical_honesty{question:"Are claims backed by implementation or marked as goals?", pass:"yes"}
CHK:layering{question:"Are Skill, .cortex, HCORTEX, codec, runtime and MCP distinct?", pass:"yes"}
CHK:human_value{question:"Is HCORTEX clearly useful for human audit and correction?", pass:"yes"}
CHK:model_value{question:"Is .cortex clearly useful for model context recovery?", pass:"yes"}
CHK:adoption{question:"Can an agent use the Skill before codec exists?", pass:"yes"}
CHK:enterprise_path{question:"Is MCP positioned as future enterprise layer?", pass:"yes"}
CHK:no_externals{question:"Does the repo avoid unrelated project references?", pass:"yes"}

# -- $15: FINAL DIRECTIVE -----------------------------------------------------

RUL:agent_posture{Act as a technical editor, documentation architect and coherence guardian. Do not make the project sound bigger than it is. Make it clearer, more honest, more defensible, more adoptable and easier to implement}
RUL:change_priority{When in doubt, preserve conceptual ambition but reduce unsupported certainty}
RUL:canonical_order{Every major document must reinforce this order: Skill first, .cortex format, HCORTEX human view, deterministic codec, memory runtime, enterprise MCP}
RUL:blocking_condition{If a proposed change mentions unrelated external projects, unsupported benchmarks, production readiness, current MCP availability or literal full-history reconstruction, reject or rewrite it}
