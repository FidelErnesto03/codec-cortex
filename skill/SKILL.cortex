# -- $0: UNIVERSAL GLOSSARY --
# Sigil | Name        | Expansion | Risk | Description
# ------+-------------+-----------+------+---------------------------------------------
# IDN   | identity    | attrs     | B    | Skill identity
# DOM   | domain      | attrs     | B    | Scope and adoption context
# AXM   | axiom       | cuerpo    | H    | Non-negotiable principle
# CNST  | constraint  | attrs     | H    | Hard boundary
# OBJ   | objective   | attrs     | B    | Active goal
# FCS   | focus       | attrs     | H    | Attention anchor
# WRK   | work        | attrs     | B    | Current operational state
# REF   | reference   | attrs     | B    | Repository reference
# HDL   | handler     | attrs     | M    | Operation descriptor with status
# PFL   | pitfall     | contenido | M    | Known risk and prevention
# DIAG  | diagram     | bloque    | M    | PUML diagram verbatim
# TAG   | tag         | attrs     | B    | Classification metadata
# STAT  | status      | attrs     | B    | Maturity declaration

# -- $0: MICRO-GLOSSARY --
# sk=Skill cx=.cortex hc=HCORTEX cd=deterministic codec rt=runtime mcp=enterprise MCP
# cur=current spec=specification pln=planned fut=future ctx=contextual str=structural

# -- $1: IDENTITY --
IDN:skill{name:"universal-codec-cortex", version:"1.1.0", license:"MIT", status:"specification/alpha"}
DOM:application{area:"LLM/SLM contextual memory", format:".cortex", adoption:"direct agent reading", language_structural:"EN", language_semantic:"user/domain"}

AXM:skill_first{CODEC-CORTEX starts as a universal Skill for contextual memory. The codec automates later; it is not required for adoption}
AXM:cortex_canonical{.cortex is the canonical persistent memory format under this protocol. Markdown, YAML and JSON may be transitional views}
AXM:hcortex_human{HCORTEX is a human-readable contextual view for audit, correction and continuity; it is not literal reconstruction of every source message}
AXM:codec_planned{The deterministic codec is planned automation for parse, encode, decode, verify and render operations}
AXM:mcp_future{Enterprise MCP is a future operating layer that exposes implemented codec/runtime operations with governance and audit}
CNST:honesty{no unsupported metrics, no current CLI/MCP claims, no inflated maturity language, no literal full-history reconstruction}
CNST:claims{metrics must be measured, target, expected or illustrative. Unmeasured token reduction remains target/illustrative}

# -- $2: CONTEXT --
FCS:primary{what:"structured contextual memory", priority:high}
OBJ:main{goal:"help agents preserve identity, focus, objective, work state, rules, sessions, lessons, knowledge and references", status:current}
WRK:adoption{mode:"read Skill + load .cortex files", requires_codec:false, requires_mcp:false}
STAT:current{items:["skill docs",".cortex examples","HCORTEX specification","direct adoption discipline"]}
STAT:planned{items:["parser","AST","encode/decode","structural verify","HCORTEX renderer","CLI"]}
STAT:future{items:["memory runtime","automatic consolidation","enterprise MCP"]}

REF:readme{PATH:README.md}
REF:status{PATH:STATUS.md}
REF:roadmap{PATH:ROADMAP.md}
REF:spec_es{PATH:skill/SKILL.md}
REF:spec_en{PATH:skill/SKILL.en.md}
REF:agent{PATH:skill/AGENT.cortex}
REF:brain_template{PATH:skill/brain.cortex}

# -- $3: OPERATIONS --
HDL:read_cortex{operation:"read .cortex", available_by_skill_now:true, requires_codec:false, status:current, notes:"direct agent reading"}
HDL:use_core_memory{operation:"use FCS/OBJ/WRK", available_by_skill_now:true, requires_codec:false, status:current, notes:"separate active intent from history"}
HDL:hcortex_basic{operation:"produce HCORTEX", available_by_skill_now:true, requires_codec:false, status:"current/specification", notes:"manual or instruction-based rendering"}
HDL:verify_formal{operation:"structural verify", available_by_skill_now:"partial", requires_codec:true, status:planned, notes:"parser required"}
HDL:encode_decode{operation:"automatic encode/decode", available_by_skill_now:false, requires_codec:true, status:planned, notes:"codec phase"}
HDL:runtime_lifecycle{operation:"compress/promote/decay lifecycle", available_by_skill_now:false, requires_codec:true, status:future, notes:"runtime phase with user-confirmed policy"}
HDL:mcp_handlers{operation:"MCP handlers", available_by_skill_now:false, requires_codec:true, status:future, notes:"enterprise layer"}
HDL:gate_exit{operation:"exit protocol", available_by_skill_now:true, requires_codec:false, status:current, notes:"render active context to HCORTEX; no literal full-history reconstruction"}

# -- $4: RULES --
!guard{FCS and OBJ must be explicit before agent action}
!canonical_memory{Persistent memory under CODEC-CORTEX is .cortex; other formats are views or interoperability surfaces}
!status_words{Every capability claim must say current, specification, planned, future or not implemented when maturity matters}
!reversibility_scope{Use structural reversibility for codec roundtrip and contextual reversibility for HCORTEX. Never claim textual reconstruction}
!codec_language{encode/decode/verify/compress/promote/decay are planned or future automation unless an implementation exists}
!mcp_language{MCP is future enterprise exposure, not first adoption mechanism}
!template_safety{Example files must not look like real operational state; placeholders and template notices are required}

# -- $5: PITFALLS --
PFL:overclaim{error:"README or docs promise completed codec behavior", solution:"mark codec/CLI as planned and point to STATUS.md"}
PFL:layer_collapse{error:"Skill, .cortex, HCORTEX, codec, runtime and MCP described as one thing", solution:"preserve canonical stack order"}
PFL:lossless_confusion{error:"contextual consolidation treated as full lossless compression", solution:"limit lossless claim to structural codec roundtrip"}
PFL:phantom_cli{error:"cortex CLI examples shown as current", solution:"mark planned or implement minimal CLI first"}
PFL:mcp_premature{error:"MCP design sounds implemented", solution:"future design banner and handler statuses"}

# -- $6: DIAGRAMS --
DIAG:canonical_stack{
@startuml
title CODEC-CORTEX Canonical Stack
rectangle "Universal Skill
current adoption layer" as skill
rectangle ".cortex
structured contextual memory" as cortex
rectangle "HCORTEX
human-readable context view" as hcortex
rectangle "Deterministic Codec
planned automation" as codec
rectangle "Memory Runtime
future lifecycle" as runtime
rectangle "Enterprise MCP
future tools/governance" as mcp
skill --> cortex
cortex --> hcortex
cortex --> codec
codec --> runtime
runtime --> mcp
@enduml
}
