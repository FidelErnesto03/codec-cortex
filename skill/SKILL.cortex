# -- $0: UNIVERSAL GLOSSARY --
# Sigil | Name        | Expansion | Risk | Description
# ------+-------------+-----------+------+---------------------------------------------
# IDN   | identity    | attrs     | B    | Skill identity
# DOM   | domain      | attrs     | B    | Scope and adoption context
# AXM   | axiom       | cuerpo    | H    | Non-negotiable principle
# CNST  | constraint  | attrs     | H    | Hard boundary
# OBJ   | objective   | attrs     | B    | Active goal
# FCS   | focus       | attrs     | H    | Attention anchor
# WRK   | work        | attrs     | B    | Current operational state
# REF   | reference   | attrs     | B    | Repository reference
# HDL   | handler     | attrs     | M    | Operation descriptor with status
# PFL   | pitfall     | contenido | M    | Known risk and prevention
# DIAG  | diagram     | bloque    | M    | PUML diagram verbatim
# TAG   | tag         | attrs     | B    | Classification metadata
# STAT  | status      | attrs     | B    | Maturity declaration
# STP   | step        | attrs     | M    | Next immediate action
# AUD   | audit       | attrs     | M    | Audit or verification record
# RSK   | risk        | attrs     | M    | Identified risk with mitigation
# NXT   | next        | attrs     | M    | Queued next action with trigger
# CLAIM | claim       | attrs     | M    | Verifiable claim
# LIM   | limit       | attrs     | M    | Explicit operational limit

# -- $0: MICRO-GLOSSARY --
# sk=Skill cx=.cortex hc=HCORTEX cd=deterministic codec rt=runtime mcp=enterprise MCP
# cur=current spec=specification pln=planned fut=future ctx=contextual str=structural

# -- $1: IDENTITY --
IDN:skill{name:"universal-codec-cortex", version:"1.1.0", license:"MIT", status:"specification/alpha"}
DOM:application{area:"LLM/SLM contextual memory", format:".cortex", adoption:"direct agent reading", language_structural:"EN", language_semantic:"user/domain"}

AXM:skill_first{CODEC-CORTEX starts as a universal Skill for contextual memory. The codec automates later; it is not required for adoption}
AXM:cortex_canonical{.cortex is the canonical persistent memory format under this protocol. Markdown, YAML and JSON may be transitional views}
AXM:hcortex_human{HCORTEX is a human-readable contextual view for audit, correction and continuity; it is not literal reconstruction of every source message}
AXM:codec_planned{The deterministic codec is planned automation for parse, encode, decode, verify and render operations}
AXM:mcp_future{Enterprise MCP is a future operating layer that exposes implemented codec/runtime operations with governance and audit}
CNST:honesty{no unsupported metrics, no current CLI/MCP claims, no inflated maturity language, no literal full-history reconstruction}
CNST:claims{metrics must be measured, target, expected or illustrative. Unmeasured token reduction remains target/illustrative}

# -- $2: CONTEXT --
FCS:primary{what:"structured contextual memory", priority:high}
OBJ:main{goal:"help agents preserve identity, focus, objective, work state, rules, sessions, lessons, knowledge and references", status:current}
WRK:adoption{mode:"read Skill + load .cortex files", requires_codec:false, requires_mcp:false}
STAT:current{items:["skill docs",".cortex examples","HCORTEX specification","direct adoption discipline"]}
STAT:planned{items:["parser","AST","encode/decode","structural verify","HCORTEX renderer","CLI"]}
STAT:future{items:["memory runtime","automatic consolidation","enterprise MCP"]}

REF:readme{PATH:README.md}
REF:status{PATH:STATUS.md}
REF:roadmap{PATH:ROADMAP.md}
REF:spec_es{PATH:skill/SKILL.md}
REF:spec_en{PATH:skill/SKILL.en.md}
REF:agent{PATH:skill/AGENT.cortex}
REF:brain_template{PATH:skill/brain.cortex}

# -- $3: OPERATIONS --
HDL:read_cortex{operation:"read .cortex", available_by_skill_now:true, requires_codec:false, status:current, notes:"direct agent reading"}
HDL:use_core_memory{operation:"use FCS/OBJ/WRK", available_by_skill_now:true, requires_codec:false, status:current, notes:"separate active intent from history"}
HDL:hcortex_basic{operation:"produce HCORTEX", available_by_skill_now:true, requires_codec:false, status:"current/specification", notes:"manual or instruction-based rendering"}
HDL:verify_formal{operation:"structural verify", available_by_skill_now:"partial", requires_codec:true, status:planned, notes:"parser required"}
HDL:encode_decode{operation:"automatic encode/decode", available_by_skill_now:false, requires_codec:true, status:planned, notes:"codec phase"}
HDL:runtime_lifecycle{operation:"compress/promote/decay lifecycle", available_by_skill_now:false, requires_codec:true, status:future, notes:"runtime phase with user-confirmed policy"}
HDL:mcp_handlers{operation:"MCP handlers", available_by_skill_now:false, requires_codec:true, status:future, notes:"enterprise layer"}
HDL:gate_exit{operation:"exit protocol", available_by_skill_now:true, requires_codec:false, status:current, notes:"render active context to HCORTEX; no literal full-history reconstruction"}

# -- $4: RULES --
!guard{FCS and OBJ must be explicit before agent action}
!canonical_memory{Persistent memory under CODEC-CORTEX is .cortex; other formats are views or interoperability surfaces}
!status_words{Every capability claim must say current, specification, planned, future or not implemented when maturity matters}
!reversibility_scope{Use structural reversibility for codec roundtrip and contextual reversibility for HCORTEX. Never claim textual reconstruction}
!codec_language{encode/decode/verify/compress/promote/decay are planned or future automation unless an implementation exists}
!mcp_language{MCP is future enterprise exposure, not first adoption mechanism}
!template_safety{Example files must not look like real operational state; placeholders and template notices are required}
!progressive_compatibility{No existing .cortex entry is invalidated by this specification. Entries without survive or minimum field contracts remain parseable and valid. Migration is voluntary and progressive}
!priority_pack{Reduce context by P5→P0 priority, never by position. Load from P0→P5. P0 (FCS,OBJ,CNST,STP) never eliminated}
!p0_immutable{FCS, OBJ, CNST, STP survive all context reductions. They have P0 survival priority}
!cnst_blocking_protected{CNST with severity:blocking and survive:min must never be omitted from MIN or RECOVERY profiles}
!direct_profile_selection{Jump directly to required profile budget: MIN (~300t), RECOVERY (~1000t), WORK (~3000t), FULL (unlimited). No sequential chain required}
!hcortex_profile_selection{Before rendering HCORTEX, resolve the active profile using this precedence: explicit_profile > available_context_budget > operational_mode > CORTEX-WORK. Budget thresholds: MIN<=512t, RECOVERY<=1000t, WORK<=3000t, FULL>3000t. MIN render target is ~300t. Include only entries whose explicit P-level, derived P-level from !priority_pack, or survive level qualifies for the active profile. Filtering is entry-level, never section-level. Entries without P-level and without survive are treated as P5. Declare the active profile as the first HCORTEX line: Perfil: CORTEX-<LEVEL>. Defaults by mode: audit->FULL, recovery->RECOVERY, active->WORK, emergency->MIN. If audit requires FULL and budget is insufficient, do not silently degrade; declare Perfil: CORTEX-FULL (segmentado) Segmento: <n>/<total or unknown> and render only the declared segment. Never label segmented audit as WORK or RECOVERY}
!hcortex_source_traceability{Every HCORTEX table derived from P0, P1, or survive:min entries must include a source column using the canonical format <SIGIL>:<name> (e.g. FCS:primary, CNST:honesty). For P2+ entries, the source column is recommended but not mandatory. The source column must be the last column in the table. PUML diagrams must include a source comment using the canonical format: ' source: DIAG:<name>. Rule bodies rendered outside tables must include inline source annotation when derived from P0/P1. If a required source is missing for P0/P1, render WARNING: missing source instead of omitting traceability}
!hcortex_multi_instance{When a sigil has multiple named instances (e.g. FCS:primary, FCS:secondary), HCORTEX must render them as distinct sub-sections using the instance name as context. The preferred format is a sub-section header per instance: ### <SIGIL>:<name>. If a unified table is more readable, include an instance column. Instances must appear in the same order as in the .cortex source file. Single-instance sigils are unaffected.}
!hcortex_expansion_render{Render each .cortex entry according to its expansion type as defined in $0. attrs: table with source+instance columns. cuerpo: indented quote with sigil prefix. contenido: contextual table (SES: I/O/R, LNG: list, PFL: Error/Cause/Solution). bloque: PUML verbatim with ' source: DIAG:<name>. attrs-pos: Command|Description table. Never render cuerpo or contenido entries as attrs-style K/V tables.}
!hcortex_render_order{Render HCORTEX sections ordered by P-level priority: P0 first, P5 last. Order: P0 (FCS/OBJ/CNST/STP) > P1 (WRK/AUD/RSK/NXT) > P2 (CLAIM/LIM/KNW/LNG) > P3 (SES/STAT/VAL/RES/FIND) > P4 (REF/DOC/ART) > P5 (DIAG/TBL/history). Sigils without P-level assignment render last, after P5. Within the same P-level, preserve the source .cortex order. This overrides .cortex section number ordering.}

# -- $5: PITFALLS --
PFL:overclaim{error:"README or docs promise completed codec behavior", solution:"mark codec/CLI as planned and point to STATUS.md"}
PFL:layer_collapse{error:"Skill, .cortex, HCORTEX, codec, runtime and MCP described as one thing", solution:"preserve canonical stack order"}
PFL:lossless_confusion{error:"contextual consolidation treated as full lossless compression", solution:"limit lossless claim to structural codec roundtrip"}
PFL:phantom_cli{error:"cortex CLI examples shown as current", solution:"mark planned or implement minimal CLI first"}
PFL:mcp_premature{error:"MCP design sounds implemented", solution:"future design banner and handler statuses"}

# -- $6: DIAGRAMS --
DIAG:canonical_stack{
@startuml
title CODEC-CORTEX Canonical Stack
rectangle "Universal Skill
current adoption layer" as skill
rectangle ".cortex
structured contextual memory" as cortex
rectangle "HCORTEX
human-readable context view" as hcortex
rectangle "Deterministic Codec
planned automation" as codec
rectangle "Memory Runtime
future lifecycle" as runtime
rectangle "Enterprise MCP
future tools/governance" as mcp
skill --> cortex
cortex --> hcortex
cortex --> codec
codec --> runtime
runtime --> mcp
@enduml
}

# -- $7: MINIMUM FIELD CONTRACTS --
# Each critical sigil declares mandatory fields + optional extensions.
# Additional fields are always permitted as long as they do not contradict the minimum contract.

# FCS — Focus (attention anchor)
# FCS:primary{what:str, priority:high|medium|low, status:active|blocked|done, survive:min|recovery|work|full}
#   what       : required — what the agent is attending to
#   priority   : required — high | medium | low
#   status     : required — active | blocked | done
#   survive    : required — suggested: work
#   + any additional fields allowed (since, owner, source, ...)

# OBJ — Objective (active mission)
# OBJ:main{goal:str, status:in_progress|done|blocked, success:str, survive:min|recovery|work|full}
#   goal       : required — objective to achieve
#   status     : required — in_progress | done | blocked
#   success    : required — verifiable success criterion
#   survive    : required — suggested: recovery
#   + any additional fields allowed (deadline, owner, depends_on, ...)

# CNST — Constraint (hard boundary)
# CNST:name{rule:str, severity:blocking|warning|info, survive:min|recovery|work|full}
#   rule       : required — the non-negotiable rule
#   severity   : required — blocking | warning | info
#   survive    : required — suggested: min if severity=blocking
#   + any additional fields allowed (scope, source, ...)

# STP — Step (next immediate action)
# STP:next{action:str, reason:str, owner:agent|human, survive:min|recovery|work|full}
#   action     : required — action to execute (infinitive verb)
#   reason     : required — why this action is next
#   owner      : required — agent | human
#   survive    : required — suggested: work
#   + any additional fields allowed (deadline, depends_on, ...)

# WRK — Work (operational state)
# WRK:state{phase:str, current:str, blocked:bool, survive:min|recovery|work|full}
#   phase      : required — current work phase
#   current    : required — what is being done now
#   blocked    : required — true | false
#   survive    : required — suggested: work
#   + any additional fields allowed (active_files, session_start, ...)

# RSK — Risk (recommended fields, not mandatory)
# RSK:name{risk:str, impact:high|medium|low, mitigation:str, survive:recovery|work|full}
# NXT — Next in queue (recommended fields, not mandatory)
# NXT:name{action:str, priority:high|medium|low, trigger:now|after_X|on_Y, survive:work|recovery|full}

# -- $8: SURVIVE ATTRIBUTE --
# survive governs which .cortex entries persist under context reduction.
# 4 levels defined:

# min      : Minimal survival (~300 tokens). Preserved even under maximum reduction.
#            Typical: CNST with severity:blocking, IDN entries.
# recovery : State recovery (~1000 tokens). Allows agent to recover objective,
#            identity and focus on reconnection. Typical: OBJ entries, RSK.
# work     : Work continuity (~3000 tokens). Preserves operational state for
#            uninterrupted work. Typical: FCS, STP, WRK, NXT.
# full     : Full context. Preserved with no or superficial reduction.
#            Typical: SES, REF, historical entries.

# Assignment rules:
#   CNST with severity:blocking  → survive:min
#   OBJ active (in_progress)     → survive:recovery
#   FCS, WRK, STP                → survive:work
#   Documentary, historical      → survive:full
#   Entries without survive      → valid (progressive compatibility)

# -- $9: PRIORITY PACK P0-P5 --
# Context is reduced by cognitive priority, never by position.
# Load order: P0→P5. Degradation order: P5→P1 (P0 never eliminated).

# P0 — Critical survival (~300t)  : FCS, OBJ, CNST, STP
# P1 — Operational state (~600t)  : WRK, AUD, RSK, NXT (when they exist)
# P2 — Honesty and limits (~1Kt)  : CLAIM, LIM, KNW:active, LNG:critical (when they exist)
# P3 — Recent evidence (~2Kt)     : SES:last, STAT, VAL, RES, FIND (when they exist)
# P4 — Critical references (~3Kt) : REF:critical, DOC, ART (when they exist)
# P5 — Extended context (unlim.)  : DIAG, TBL, long REF, history, comments

# Rules:
#   Anti-positional truncation: never reduce by tail/head position
#   P0 immutable: FCS,OBJ,CNST,STP survive all reductions
#   CNST:blocking with survive:min → never omitted
#   CLAIM/LIM that block public claims → survive at least RECOVERY
#   "When they exist": P1-P5 sigils not found → level has fewer entries (not an error)

# -- $10: CONTEXT PROFILES --
# Four conceptual profiles by minimum priority, not by closed sigil lists.

# CORTEX-MIN      : Emergency. P0 only. ~300 tokens.
#                   Survives: FCS, OBJ, CNST, STP. CNST:blocking always.
# CORTEX-RECOVERY : After interruption. P0+P1. ~1000 tokens.
#                   Survives: P0 + WRK, AUD, RSK, NXT (when they exist).
# CORTEX-WORK     : Work continuity. P0+P1+P2. ~3000 tokens.
#                   Survives: RECOVERY + CLAIM, LIM, KNW:active, LNG:critical.
# CORTEX-FULL     : Complete memory. P0–P5. Unlimited.
#                   Survives: everything.

# Profile selection: jump directly to required budget. No sequential chain.
#   ≤512 tokens       → CORTEX-MIN
#   ≤1000 tokens      → CORTEX-RECOVERY
#   ≤3000 tokens      → CORTEX-WORK
#   >3000 tokens      → CORTEX-FULL

# HCORTEX is NOT a profile. HCORTEX is a render target:
#   - Generated from the active profile, not persisted as .cortex
#   - P0/P1 entries must be traceable to their source .cortex sigil
#   - Minimum equivalences: FCS→"Foco actual", OBJ→"Objetivo", CNST→"Restricciones",
#     WRK→"Estado operativo", STP/NXT→"Próximo paso", AUD/RSK→"Evidencia/Riesgos",
#     CLAIM/LIM→"Límites de afirmación"

# HCORTEX render procedure:
#   Step 1: resolve active profile by precedence:
#            explicit_profile > context_budget > mode > CORTEX-WORK
#   Step 2: declare profile as first HCORTEX line:
#            "Perfil: CORTEX-<LEVEL>"
#   Step 3: filter entries by P-level or survive matching the profile.
#            Entries without P-level or survive → P5 (excluded unless FULL).
#            Filtering is entry-level, never section-level.
#   Step 4: render only filtered entries.
#   Audit with insufficient budget: do not silently degrade.
#            Declare "Perfil: CORTEX-FULL (segmentado) Segmento: <n>/<total>"
#            and render only the declared segment.
#   Step 5: add source column to P0/P1 tables using <SIGIL>:<name> format.
#            PUML diagrams include ' source: DIAG:<name>.
#            If source missing for P0/P1, render WARNING: missing source.
#   Step 6: if a sigil has multiple named instances (FCS:primary, FCS:secondary),
#            render as distinct sub-sections: ### <SIGIL>:<name>. Preserve source order.
#   Step 7: apply render strategy by expansion type from $0:
#            attrs: table with source+instance columns.
#            cuerpo: indented quote with sigil prefix.
#            contenido: contextual table (SES: I/O/R, LNG: list, PFL: Error/Cause/Solution).
#            bloque: PUML verbatim with ' source: DIAG:<name>.
#            attrs-pos: Command|Description table.
#   Step 8: order sections by P-level priority: P0 first, P5 last.
#            Sigils without P-level assignment render last, after P5.
#            Within the same P-level, preserve the source .cortex order.

# -- $11: DEGRADATION POLICY --
# Conceptual chain: FULL → WORK → RECOVERY → MIN
# Operational selection: direct jump to required profile by budget.

# What disappears first (when degrading):
#   FULL → WORK       : DIAG, TBL long, REF long, SES historical, comments
#   WORK → RECOVERY   : KNW complete→KNW:active, LNG complete→LNG:critical, REF→REF:critical
#   RECOVERY → MIN    : SES:last, AUD, RSK, NXT, STAT. Only P0 survives.

# What NEVER disappears:
#   In any profile    : CNST with severity:blocking and survive:min
#   In any profile    : FCS, OBJ, STP (P0 immutable)
#   At least RECOVERY : CLAIM, LIM that block public claims
